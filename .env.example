# Knowledge2 SDK Configuration
# Copy this file to .env and fill in your values.

# API Key (required for most operations)
# K2_API_KEY=k2_your_api_key_here

# API Host (optional, defaults to https://api.knowledge2.ai)
# K2_API_HOST=https://api.knowledge2.ai

# Organization ID (optional, auto-detected from API key if not set)
# K2_ORG_ID=your-org-id
